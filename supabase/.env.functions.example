# Do not upload this file to hosting or commit real values to GitHub.
# Set these through Supabase Dashboard -> Edge Functions -> Secrets,
# or with: supabase secrets set --env-file supabase/.env.functions.local
RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET

# Comma-separated application origins allowed to call authenticated payment functions.
# Include the Cloudflare workers.dev preview and final custom domain while testing.
APP_ORIGINS=https://evidara.example.workers.dev,https://app.evidara.in
