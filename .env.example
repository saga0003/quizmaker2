# Public Supabase configuration used by the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Use only when the project still exposes the legacy anon key instead of a publishable key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Configure as a Cloudflare Worker secret; never expose it to browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical production URL, for example https://app.evidara.in
NEXT_PUBLIC_APP_URL=
