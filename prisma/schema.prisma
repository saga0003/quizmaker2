// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ENUMS
enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  TEACHER
  CONTENT_CREATOR
  PROCTOR
  STUDENT
  PARENT
  SUPPORT
  ANALYST
}

enum QuestionType {
  MCQ_SINGLE
  MCQ_MULTI
  INTEGER
  NUMERIC_RANGE
  ASSERTION_REASON
  MATRIX_MATCH
  FILL_IN_BLANK
  ORDERING
  DESCRIPTIVE
}

enum QuestionStatus {
  DRAFT
  REVIEWED
  APPROVED
  ARCHIVED
}

enum CognitiveLevel {
  RECALL
  UNDERSTAND
  APPLY
  ANALYZE
  EVALUATE
}

enum TestMode {
  PRACTICE
  TIMED_PRACTICE
  PROCTORED
  CENTER_BASED
  HOMEWORK
}

enum TestStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AttemptStatus {
  IN_PROGRESS
  COMPLETED
  SUBMITTED
  ABANDONED
  TIMED_OUT
}

enum ProctoringFlag {
  FACE_NOT_VISIBLE
  MULTIPLE_FACES
  NO_PERSON
  BACKGROUND_VOICE
  GAZE_AWAY
  TAB_SWITCH
  COPY_PASTE
  PRINT_ATTEMPT
}

// CORE MODELS
model Organization {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  logo            String?
  domain          String?
  theme           Json?
  custom_settings Json?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  users           User[]
  subjects        Subject[]
  tests           Test[]
  test_templates  TestTemplate[]
  
  @@map("organizations")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  phone           String?
  name            String?
  avatar          String?
  role            UserRole @default(STUDENT)
  organization_id String?
  is_active       Boolean  @default(true)
  email_verified  Boolean  @default(false)
  phone_verified  Boolean  @default(false)
  two_factor_enabled Boolean @default(false)
  preferences     Json?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  organization    Organization? @relation(fields: [organization_id], references: [id])
  created_questions Question[] @relation("CreatedBy")
  reviewed_questions Question[] @relation("ReviewedBy")
  created_tests    Test[] @relation("CreatedBy")
  test_attempts   TestAttempt[]
  assigned_tests  TestAssignment[]
  analytics       UserAnalytics?
  
  @@map("users")
}

// TAXONOMY MODELS
model Subject {
  id              String   @id @default(cuid())
  name            String
  code            String?
  description     String?
  organization_id String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  chapters        Chapter[]
  questions       Question[]
  
  @@unique([name, organization_id])
  @@map("subjects")
}

model Chapter {
  id          String   @id @default(cuid())
  name        String
  code        String?
  description String?
  subject_id  String
  order       Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  subject     Subject  @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  topics      Topic[]
  questions   Question[]
  
  @@unique([name, subject_id])
  @@map("chapters")
}

model Topic {
  id          String   @id @default(cuid())
  name        String
  code        String?
  description String?
  chapter_id  String
  order       Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  chapter     Chapter  @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  subtopics   SubTopic[]
  questions   Question[]
  
  @@unique([name, chapter_id])
  @@map("topics")
}

model SubTopic {
  id          String   @id @default(cuid())
  name        String
  code        String?
  description String?
  topic_id    String
  order       Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  topic       Topic    @relation(fields: [topic_id], references: [id], onDelete: Cascade)
  questions   Question[]
  
  @@unique([name, topic_id])
  @@map("sub_topics")
}

// QUESTION BANK MODELS
model Question {
  id                  String          @id @default(cuid())
  title               String?
  content             String
  type                QuestionType
  status              QuestionStatus  @default(DRAFT)
  difficulty          Int             @default(3) // 1-5 scale
  cognitive_level     CognitiveLevel  @default(RECALL)
  estimated_time      Int             @default(60) // in seconds
  marks               Float           @default(1)
  negative_marks      Float           @default(0)
  subject_id          String
  chapter_id          String?
  topic_id            String?
  sub_topic_id        String?
  created_by_id       String
  reviewed_by_id      String?
  explanation         String?
  past_exam_mapping   String?
  tags                String?         // JSON string array of tags
  partial_marking     Boolean         @default(false)
  shuffle_options     Boolean         @default(true)
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt

  // Relations
  subject             Subject         @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  chapter             Chapter?        @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  topic               Topic?          @relation(fields: [topic_id], references: [id], onDelete: Cascade)
  sub_topic           SubTopic?       @relation(fields: [sub_topic_id], references: [id], onDelete: Cascade)
  created_by          User            @relation("CreatedBy", fields: [created_by_id], references: [id])
  reviewed_by         User?           @relation("ReviewedBy", fields: [reviewed_by_id], references: [id])
  options             QuestionOption[]
  solutions           QuestionSolution[]
  test_questions      TestQuestion[]
  responses           TestResponse[]
  analytics           QuestionAnalytics?
  
  @@map("questions")
}

model QuestionOption {
  id          String  @id @default(cuid())
  question_id String
  content     String
  is_correct  Boolean @default(false)
  order       Int     @default(0)
  rationale   String?
  
  // Relations
  question    Question @relation(fields: [question_id], references: [id], onDelete: Cascade)
  selected_options TestResponseSelectedOptions[] @relation("SelectedOptions")
  
  @@map("question_options")
}

model QuestionSolution {
  id          String  @id @default(cuid())
  question_id String
  content     String
  type        String  @default("text") // text, image, video, file
  order       Int     @default(0)
  
  // Relations
  question    Question @relation(fields: [question_id], references: [id], onDelete: Cascade)
  
  @@map("question_solutions")
}

// TEST & ASSESSMENT MODELS
model TestTemplate {
  id              String   @id @default(cuid())
  name            String
  description     String?
  type            String   // full-length, part-test, chapter-test, topic-test, mixed-mock, custom
  organization_id String
  blueprint       Json     // Blueprint for auto-assembly
  settings        Json     // Default settings for tests created from this template
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  tests           Test[]
  
  @@map("test_templates")
}

model Test {
  id              String     @id @default(cuid())
  title           String
  description     String?
  code            String?
  template_id     String?
  organization_id String
  mode            TestMode   @default(PRACTICE)
  status          TestStatus @default(DRAFT)
  duration        Int        // Total duration in minutes
  start_time      DateTime?
  end_time        DateTime?
  max_attempts    Int        @default(1)
  shuffle_questions Boolean  @default(true)
  shuffle_options Boolean   @default(true)
  show_results    Boolean   @default(true)
  show_solutions  Boolean   @default(false)
  allow_review    Boolean   @default(true)
  negative_marking Json     // Negative marking rules
  passing_marks   Float?
  total_marks     Float?
  instructions    String?
  settings        Json?
  created_by_id   String
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  // Relations
  template        TestTemplate?  @relation(fields: [template_id], references: [id])
  organization    Organization   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  created_by      User           @relation("CreatedBy", fields: [created_by_id], references: [id])
  sections        TestSection[]
  questions       TestQuestion[]
  attempts        TestAttempt[]
  assignments      TestAssignment[]
  
  @@map("tests")
}

model TestSection {
  id          String   @id @default(cuid())
  test_id     String
  name        String
  description String?
  order       Int      @default(0)
  duration    Int?     // Section duration in minutes
  marks       Float?
  instructions String?
  settings    Json?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  test        Test     @relation(fields: [test_id], references: [id], onDelete: Cascade)
  questions   TestQuestion[]
  
  @@map("test_sections")
}

model TestQuestion {
  id          String   @id @default(cuid())
  test_id     String
  section_id  String?
  question_id String
  order       Int      @default(0)
  marks       Float?
  negative_marks Float?
  settings    Json?
  
  // Relations
  test        Test     @relation(fields: [test_id], references: [id], onDelete: Cascade)
  section     TestSection? @relation(fields: [section_id], references: [id], onDelete: Cascade)
  question    Question @relation(fields: [question_id], references: [id], onDelete: Cascade)
  responses   TestResponse[]
  
  @@unique([test_id, question_id])
  @@map("test_questions")
}

model TestAssignment {
  id              String   @id @default(cuid())
  test_id         String
  user_id         String?
  assigned_to     String?  // Email or user identifier
  assigned_by     String
  assigned_at     DateTime @default(now())
  start_time      DateTime?
  end_time        DateTime?
  max_attempts    Int      @default(1)
  attempts_used   Int      @default(0)
  status          String   @default("pending") // pending, started, completed, expired
  settings        Json?
  
  // Relations
  test            Test     @relation(fields: [test_id], references: [id], onDelete: Cascade)
  user            User?    @relation(fields: [user_id], references: [id])
  attempts        TestAttempt[]
  
  @@map("test_assignments")
}

// ATTEMPT & RESPONSE MODELS
model TestAttempt {
  id              String        @id @default(cuid())
  test_id         String
  user_id         String
  assignment_id   String?
  attempt_number  Int           @default(1)
  status          AttemptStatus @default(IN_PROGRESS)
  start_time      DateTime      @default(now())
  end_time        DateTime?
  submitted_at    DateTime?
  total_time      Int           // Total time taken in seconds
  total_marks     Float?
  obtained_marks  Float?
  percentage      Float?
  rank            Int?
  percentile      Float?
  answers         Json?         // Store all answers for quick retrieval
  settings        Json?
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  // Relations
  test            Test          @relation(fields: [test_id], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  assignment      TestAssignment? @relation(fields: [assignment_id], references: [id])
  responses       TestResponse[]
  proctor_events  ProctoringEvent[]
  
  @@unique([test_id, user_id, attempt_number])
  @@map("test_attempts")
}

model TestResponse {
  id              String   @id @default(cuid())
  attempt_id      String
  question_id     String
  test_question_id String
  selected_option String?  // For MCQ - stores option IDs
  text_answer     String?  // For descriptive, fill-in-blank
  numeric_answer  Float?   // For integer, numeric range
  answer_json     Json?    // For complex answer types
  is_correct      Boolean?
  marks_obtained  Float?
  time_spent      Int      // Time spent in seconds
  confidence      Int?     // 1-5 scale
  flag            Boolean  @default(false) // For review
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  attempt         TestAttempt     @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  question        Question        @relation(fields: [question_id], references: [id], onDelete: Cascade)
  test_question   TestQuestion    @relation(fields: [test_question_id], references: [id], onDelete: Cascade)
  selected_options_mapping TestResponseSelectedOptions[] @relation("SelectedOptionsMapping")
  
  @@unique([attempt_id, question_id])
  @@map("test_responses")
}

// Many-to-many relationship for TestResponse and QuestionOption
model TestResponseSelectedOptions {
  test_response_id String
  question_option_id String
  
  test_response  TestResponse  @relation("SelectedOptionsMapping", fields: [test_response_id], references: [id], onDelete: Cascade)
  question_option QuestionOption @relation("SelectedOptions", fields: [question_option_id], references: [id], onDelete: Cascade)
  
  @@id([test_response_id, question_option_id])
  @@map("test_response_selected_options")
}

// PROCTORING MODELS
model ProctoringEvent {
  id          String         @id @default(cuid())
  attempt_id  String
  event_type  ProctoringFlag
  timestamp   DateTime       @default(now())
  metadata    Json?
  severity    String         @default("low") // low, medium, high
  screenshot  String?        // Base64 encoded image
  created_at  DateTime       @default(now())

  // Relations
  attempt     TestAttempt    @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  
  @@map("proctoring_events")
}

// ANALYTICS MODELS
model QuestionAnalytics {
  id              String   @id @default(cuid())
  question_id     String
  total_attempts  Int      @default(0)
  correct_attempts Int     @default(0)
  average_time    Float    @default(0)
  difficulty_index Float   @default(0)
  discrimination_index Float @default(0)
  option_stats    Json?    // Statistics for each option
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  question        Question @relation(fields: [question_id], references: [id], onDelete: Cascade)
  
  @@unique([question_id])
  @@map("question_analytics")
}

model UserAnalytics {
  id              String   @id @default(cuid())
  user_id         String
  total_attempts  Int      @default(0)
  total_time      Int      @default(0)
  average_score   Float    @default(0)
  accuracy        Float    @default(0)
  strong_topics   Json?
  weak_topics     Json?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  @@unique([user_id])
  @@map("user_analytics")
}